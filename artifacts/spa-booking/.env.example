# Copy file này thành .env và điền giá trị thật. KHÔNG commit file .env thật
# (file .env đã có trong .gitignore của repo).

# Google reCAPTCHA v2 — Site key (lấy tại https://www.google.com/recaptcha/admin,
# chọn loại "reCAPTCHA v2 - Checkbox", domain thêm localhost để test local).
VITE_RECAPTCHA_SITE_KEY=

# Nếu backend chạy ở domain/port khác (ví dụ deploy thật), set base URL tại đây.
# Khi chạy local qua `pnpm run dev`, để trống là được vì Vite đã proxy /api -> :5000.
# VITE_API_BASE_URL=
