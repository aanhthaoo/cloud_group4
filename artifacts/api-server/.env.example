# Copy file này thành .env và điền giá trị thật. KHÔNG commit file .env thật.

PORT=5000

# Firebase Admin SDK — đường dẫn tới file service-account.json (đặt cùng cấp với .env)
# hoặc dùng FIREBASE_SERVICE_ACCOUNT_JSON nếu deploy lên Cloud Run / môi trường không có file.
FIREBASE_CREDENTIALS_PATH=service-account.json
# FIREBASE_SERVICE_ACCOUNT_JSON=

# Firebase Web API Key (Project Settings -> General -> Web API Key)
FIREBASE_API_KEY=

# Cloudflare R2 Configuration
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_ASSETS=
R2_BUCKET_RECEIPTS=

# Google reCAPTCHA v2 — Secret key (lấy tại https://www.google.com/recaptcha/admin)
RECAPTCHA_SECRET_KEY=

# Google Cloud Vision API dùng CHUNG service account với Firebase Admin SDK ở trên.
# Yêu cầu: bật "Cloud Vision API" trong GCP Console cho đúng project, và project
# phải gắn billing account (Vision API có free tier nhưng vẫn cần billing được bật).
